      "notes": "No ci.yml is present; heuristic selection should prefer the primary Go test workflow."
    },
    {
      "id": "requests",
      "repo": "psf/requests",
      "expected_workflow_selection": "heuristic_local_workflow",
      "expected_selected_workflow_path": ".github/workflows/run-tests.yml",
      "notes": "No ci.yml is present; heuristic selection should prefer the named tests workflow."
    }
  ]
